{
  "expo": {
    "name": "BlueDiesel",
    "slug": "portable-refill-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "portablerefillapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "BlueDiesel uses your location to show nearby refilling stations on the map."
      }
    },
    "android": {
      "package": "com.bluediesel.refillkiosk",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#082E44",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "BlueDiesel uses your location to show nearby refilling stations on the map."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#082E44",
          "dark": {
            "backgroundColor": "#082E44"
          }
        }
      ],
      "expo-mail-composer"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "API_BASE_URL": "https://cp1.interion.com.sg",
      "API_TIMEOUT": "30000",
      "FIUU_ENV": "sandbox",
      "APP_ENV": "development",
      "ENABLE_MOCK_API": "true",
      "ENABLE_DEBUG_LOGGING": "true",
      "PAYMENT_POLL_INTERVAL": "2000",
      "FUELING_POLL_INTERVAL": "1000",
      "router": {},
      "eas": {
        "projectId": "f160bf0b-bc7f-4d83-9cc4-59ed69b21d11"
      }
    },
    "owner": "dreadrom"
  }
}
