# ── Station identity ──────────────────────────────────────────────────────────
STATION_ID=station-001
STATION_NAME=Portable Refill Station 1

# ── Hardware mode ─────────────────────────────────────────────────────────────
# REAL  — full GPIO + RS485 Modbus (production on ODROID-M2)
# STUB  — fully simulated (development, no hardware needed)
HARDWARE_MODE=STUB

# ── AWS IoT Core ──────────────────────────────────────────────────────────────
AWS_IOT_ENDPOINT=xxxxxxxxxxxxxx.iot.ap-southeast-1.amazonaws.com
AWS_IOT_PORT=8883
IOT_CERT_PATH=./certs/device-certificate.pem.crt
IOT_KEY_PATH=./certs/private.pem.key
IOT_CA_PATH=./certs/AmazonRootCA1.pem
MQTT_TOPIC_PREFIX=acerev/stations

# ── GPIO chip (ODROID-M2, Ubuntu) ─────────────────────────────────────────────
# Run `gpiodetect` on the board to confirm the correct chip name.
# RK3588S2 typically:
#   gpiochip0 → GPIO0  (lines 0–31)
#   gpiochip1 → GPIO1  (lines 0–31)  ← 40-pin header bank
#   gpiochip2 → GPIO2  (lines 0–31)
#   gpiochip3 → GPIO3  (lines 0–31)
#   gpiochip4 → GPIO4  (lines 0–31)
# Use `gpioinfo /dev/gpiochip1` to list lines and verify your header pins.
GPIO_CHIP=/dev/gpiochip1

# ── MK325 Pulser (Piusi, ~160 P/L, dual reed switch) ─────────────────────────
# Wire:  MK325 V+ → 3.3V pin,  MK325 GND → GND
#        MK325 CH1 → GPIO pin for PULSER_CH1_LINE
#        MK325 CH2 → GPIO pin for PULSER_CH2_LINE
PULSER_CH1_LINE=4
PULSER_CH2_LINE=5
PULSER_K_FACTOR=160.0           # pulses per litre — calibrate with known volume
PULSER_DEBOUNCE_MS=5            # ignore bounces within 5ms

# ── Pump motor relay (BOM C4 — 4-ch opto-isolated relay module) ──────────────
# The Piusi Suzzarablue AC pump has a built-in bypass valve, so the pump relay
# is the SOLE flow-control mechanism.  No solenoid valve is used.
# Wire:  Relay IN → GPIO pin,  Relay VCC → 3.3V,  Relay GND → GND
# PUMP_RELAY_ACTIVE_HIGH=true if HIGH on IN energises the relay
# Set false for most opto-isolated boards (which are active-LOW)
PUMP_RELAY_LINE=6
PUMP_RELAY_ACTIVE_HIGH=false

# ── Limit switch (Normally-Closed, overflow / interlock protection) ───────────
# Wire:  Switch A → GPIO pin (pull-up enabled),  Switch B → GND
# HIGH = circuit intact (OK), LOW = switch tripped (fault)
LIMIT_SWITCH_LINE=8

# ── RS485 Modbus RTU — gauge level sensor (BOM C3 USB-RS485 adapter) ─────────
# Run `ls /dev/ttyUSB*` to confirm the port name after plugging in the adapter.
RS485_PORT=/dev/ttyUSB0
RS485_BAUDRATE=9600
RS485_PARITY=N                  # N=none, E=even, O=odd
RS485_STOPBITS=1
LEVEL_SENSOR_ADDR=1             # Modbus slave address (check sensor label/manual)
LEVEL_SENSOR_REG=0              # Holding register address for level reading
LEVEL_SENSOR_SCALE=0.1          # raw_value × scale = level %  (e.g. 750 × 0.1 = 75.0%)
LEVEL_SENSOR_TIMEOUT_S=1.0

# ── Polling & timing ──────────────────────────────────────────────────────────
SENSOR_POLL_INTERVAL_S=5.0      # level + limit switch poll cadence (seconds)
HEARTBEAT_INTERVAL_S=30.0       # MQTT heartbeat cadence (seconds)

# ── Local diagnostics API ─────────────────────────────────────────────────────
DIAG_API_PORT=8080

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
