# hardware_service environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Station identity ────────────────────────────────────────────────────────
STATION_ID=demo-station-001
STATION_NAME=T001 - R&R Ayer Keroh

# ── AWS IoT Core ─────────────────────────────────────────────────────────────
AWS_IOT_ENDPOINT=xxxxxxxxxxxxxxx-ats.iot.ap-southeast-1.amazonaws.com
AWS_IOT_PORT=8883
# Paths to mTLS certificates provisioned in AWS IoT Core
IOT_CERT_PATH=certs/device-certificate.pem.crt
IOT_KEY_PATH=certs/private.pem.key
IOT_CA_PATH=certs/AmazonRootCA1.pem

# ── MQTT topic prefix ────────────────────────────────────────────────────────
# Topics follow the pattern: acerev/stations/{STATION_ID}/{subtopic}
MQTT_TOPIC_PREFIX=acerev/stations

# ── PLC / Hardware interface ─────────────────────────────────────────────────
# Set HARDWARE_MODE to one of: STUB | GPIO | SNAP7 | MODBUS
HARDWARE_MODE=STUB

# Siemens S7 (HARDWARE_MODE=SNAP7)
PLC_HOST=192.168.1.50
PLC_RACK=0
PLC_SLOT=1

# Modbus TCP (HARDWARE_MODE=MODBUS)
MODBUS_HOST=192.168.1.50
MODBUS_PORT=502

# RPi GPIO pin numbers (HARDWARE_MODE=GPIO, BCM numbering)
GPIO_VALVE_PIN=17        # Output: opens/closes solenoid valve
GPIO_FLOW_PIN=27         # Input: flow pulse sensor (interrupt)
GPIO_ESTOP_PIN=22        # Input: emergency stop button (pull-up)
FLOW_PULSES_PER_LITRE=450  # Calibration for YF-S201 class sensors

# ── Diagnostics API (local HTTP) ────────────────────────────────────────────
DIAG_API_PORT=8080

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR
