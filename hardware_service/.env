# hardware_service environment variables
# Configuration for STUB mode testing (no physical hardware required)

# ── Station identity ────────────────────────────────────────────────────────
STATION_ID=demo-station-001
STATION_NAME=Demo Station - Testing

# ── AWS IoT Core ─────────────────────────────────────────────────────────────
# STUB mode doesn't require AWS IoT Core connection
# These are placeholder values for testing
AWS_IOT_ENDPOINT=placeholder-ats.iot.ap-southeast-1.amazonaws.com
AWS_IOT_PORT=8883
IOT_CERT_PATH=certs/device-certificate.pem.crt
IOT_KEY_PATH=certs/private.pem.key
IOT_CA_PATH=certs/AmazonRootCA1.pem

# ── MQTT topic prefix ────────────────────────────────────────────────────────
MQTT_TOPIC_PREFIX=bluediesel/stations

# ── PLC / Hardware interface ─────────────────────────────────────────────────
# STUB mode = Fully simulated, no hardware needed!
HARDWARE_MODE=STUB

# Siemens S7 (not used in STUB mode)
PLC_HOST=192.168.1.50
PLC_RACK=0
PLC_SLOT=1

# Modbus TCP (not used in STUB mode)
MODBUS_HOST=192.168.1.50
MODBUS_PORT=502

# GPIO pins (not used in STUB mode)
GPIO_VALVE_PIN=17
GPIO_FLOW_PIN=27
GPIO_ESTOP_PIN=22
FLOW_PULSES_PER_LITRE=450

# ── Diagnostics API (local HTTP) ────────────────────────────────────────────
DIAG_API_PORT=8080

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
